# --- Database ---
# Local dev (XAMPP MySQL, user root, no password):
DB_URL=mysql+pymysql://root:@localhost:3306/statejar
# Railway production (from the MySQL plugin's variables):
# DB_URL=mysql+pymysql://root:PASSWORD@HOST:PORT/railway

# --- Auth ---
# Long random string (32+ chars), e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-long-random-secret

# --- Provider-key encryption (AES-256-GCM) ---
# Any strong random string; it is hashed to a 32-byte key.
AES_KEY=replace-with-a-long-random-secret

# --- CORS ---
# JSON list of allowed frontend origins.
CORS_ORIGINS=["http://localhost:5173","https://statejar.vercel.app","https://statejar.com","https://www.statejar.com"]
